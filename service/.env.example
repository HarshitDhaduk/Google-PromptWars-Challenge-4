# Copy to .env and fill in what you need. Every variable is optional:
# without GEMINI_API_KEY the service runs in demo mode (mock provider).

# Google AI Studio API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Gemini model used for chat (function calling required)
GEMINI_MODEL=gemini-2.5-flash

# Deterministic crowd simulation seed
CROWD_SEED=2026

# Accelerated demo clock: sim-minutes advanced per real minute, and the
# sim start relative to kickoff (-45 = 45 minutes before kickoff)
DEMO_SPEED=30
DEMO_START_OFFSET_MIN=-45

# Origin allowed by CORS (the Next.js dev server)
WEB_ORIGIN=http://localhost:3000

# Bind address for the service
HOST=127.0.0.1
PORT=8000
